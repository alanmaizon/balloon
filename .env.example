# Copy to .env and fill in. .env is gitignored.

# Anthropic API key — for the Claude agent loop.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs API key — for voice synthesis.
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs voice palette. Claude picks one based on character traits.
# List your voices: curl -H "xi-api-key: $ELEVENLABS_API_KEY" https://api.elevenlabs.io/v1/voices | jq '.voices[] | {voice_id, name}'
# The five names below are fixed — Claude knows them. Replace the IDs with whatever fits.
VOICE_GRAVELLY_OLD=21m00Tcm4TlvDq8ikWAM
VOICE_CHEERFUL_YOUNG=AZnzlk1XvdvUeBnXmlld
VOICE_MYSTERIOUS_LOW=EXAVITQu4vr4xnSDxMaB
VOICE_WARRIOR_STRONG=MF3mGyEYCl7XYWbV9V6O
VOICE_MERCHANT_SMOOTH=TxGEqnHWrfWFTfGW9XjX
